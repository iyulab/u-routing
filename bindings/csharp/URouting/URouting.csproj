<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>URouting</RootNamespace>
    <AssemblyName>URouting</AssemblyName>
    <PackageId>URouting</PackageId>
    <Version>0.2.3</Version>
    <Authors>iyulab</Authors>
    <Description>Vehicle routing optimization (TSP, CVRP, VRPTW) — Rust engine with C# bindings.</Description>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Native library bundling (4 platforms) -->
    <None Include="runtimes/win-x64/native/u_routing.dll"
          Pack="true" PackagePath="runtimes/win-x64/native/"
          Condition="Exists('runtimes/win-x64/native/u_routing.dll')" />
    <None Include="runtimes/linux-x64/native/libu_routing.so"
          Pack="true" PackagePath="runtimes/linux-x64/native/"
          Condition="Exists('runtimes/linux-x64/native/libu_routing.so')" />
    <None Include="runtimes/osx-x64/native/libu_routing.dylib"
          Pack="true" PackagePath="runtimes/osx-x64/native/"
          Condition="Exists('runtimes/osx-x64/native/libu_routing.dylib')" />
    <None Include="runtimes/osx-arm64/native/libu_routing.dylib"
          Pack="true" PackagePath="runtimes/osx-arm64/native/"
          Condition="Exists('runtimes/osx-arm64/native/libu_routing.dylib')" />
  </ItemGroup>

</Project>
